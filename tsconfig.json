{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2022",
		"lib": [
			"ES2022"
		],
		"outDir": "out",
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"types": [
			"node", // Fixes 'node:child_process' name error
			"vscode" // Ensures VS Code API types are loaded
		]
	},
	"exclude": [
		"node_modules",
		".vscode-test"
	]
}